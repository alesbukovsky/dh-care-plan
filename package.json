{
	"name": "dh-care-plan",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "bun run --cwd packages/pwa dev",
		"build": "bun run --cwd packages/pwa build",
		"test": "bun run --cwd packages/pwa test",
		"test:core": "cd packages/core && bun test",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"lint:md": "markdownlint-cli2",
		"lint:md:fix": "markdownlint-cli2 --fix",
		"format": "biome format --write .",
		"check": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.5",
		"@types/bun": "latest",
		"markdownlint-cli2": "0.23.1"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
